# ==========================================
# ACP UI - Global Configuration Template
# ==========================================

# --- Network & Ports ---
BACKEND_PORT=3005
FRONTEND_PORT=5173
HOST=localhost

# --- Provider Configuration ---
# Multi-provider registry file. Defaults to ./configuration/providers.json if not set.
# ACP_PROVIDERS_CONFIG=./configuration/providers.json

# --- Secrets ---
# Required for specific providers if not using local OAuth
PROVIDER_API_KEY=<your-api-key>

# --- Workspace & Config Files ---
WORKSPACES_CONFIG=./configuration/workspaces.json
COMMANDS_CONFIG=./configuration/commands.json
COUNSEL_CONFIG=./configuration/counsel.json
MCP_CONFIG=./configuration/mcp.json

# --- Storage & Persistence ---
UI_DATABASE_PATH=./persistence.db

# --- Sidebar & UI Behavior ---
SIDEBAR_DELETE_PERMANENT=false   # true = permanent delete, false = archive
NOTIFICATION_SOUND=true
NOTIFICATION_DESKTOP=false

# --- Voice STT (optional) ---
VOICE_STT_ENABLED=false
STT_PORT=9777

# --- Application Tuning ---
STREAM_FLUSH_INTERVAL_MS=16
MAX_SHELL_RESULT_LINES=1000
UI_NOTIFICATION_DELAY_MS=2000
PROCESS_WARMUP_DELAY_MS=2000
RECONNECT_INTERVAL_MS=1000

# --- Logging
LOG_FILE_PATH=./logs/backend_logs.txt
LOG_MESSAGE_CHUNKS=false
