{
  "command": "codex-acp",
  "args": [],
  "authMethod": "auto",
  "fetchQuotaStatus": true,
  "refreshQuotaOAuth": true,
  "quotaStatusIntervalMs": 30000,
  "defaultSubAgentName": "general-assistant",
  "paths": {
    "home": "%USERPROFILE%\\.codex",
    "sessions": "%USERPROFILE%\\.codex\\sessions",
    "agents": "%USERPROFILE%\\.codex\\agents",
    "attachments": "%USERPROFILE%\\.codex\\attachments",
    "archive": "%USERPROFILE%\\.codex\\archive"
  },
    "models": {
        "default": "gpt-5.5/xhigh",
        "quickAccess": [
            { "id": "gpt-5.5/xhigh", "displayName": "GPT 5.5", "description": "Highest capability" },
            { "id": "gpt-5.3-codex/high", "displayName": "GPT 5.3 Codex", "description": "Balanced everyday work" },
            { "id": "gpt-5.4-mini/medium", "displayName": "GPT 5.4 Mini", "description": "Fastest responses" }
        ],
        "titleGeneration": "gpt-5.4-mini/low",
        "subAgent": "gpt-5.4-mini/medium"
    }
}
